def time_to_hours_v1(time_str):
    """Convert 'H:MM:SS' or 'HH:MM:SS' string to decimal hours."""
    # i think better to transform to seconds and then to hours, to avoid any issues with formatting        
    parts = time_str.strip().split(":")
    h, m, s = int(parts[0]), int(parts[1]), int(parts[2])
    return h + m / 60.0 + s / 3600.0

def time_to_hours(time_str):
    """Convert 'H:MM:SS' or 'HH:MM:SS' string to decimal hours."""
    parts = time_str.strip().split(":")
    h, m, s = map(int, parts)
    total_seconds = h * 3600 + m * 60 + s
    print(h,m,s,total_seconds)
    return total_seconds / 3600.0

def parse_plate_reader_no_deleting_points(filepath):
    """
    Parse a Synergy H1 kinetic export into one DataFrame per read type.

    Returns
    -------
    dict  :  { 'Read 1:600': DataFrame, 'Read 2:457,510': ..., ... }
             Each DataFrame has columns = well names (e.g. 'B1') and
             index = time in hours.
    """
    with open(filepath, "r", encoding="latin-1") as f:
        raw_lines = f.readlines()

    # Strip carriage returns
    lines = [l.rstrip("\r\n") for l in raw_lines]

    # Locate section headers like "Read 1:600", "Read 2:457,510", etc.
    section_starts = []
    for i, line in enumerate(lines):
        if re.match(r"^Read \d+:", line):
            section_starts.append((i, line.strip()))

    data_blocks = {}

    for idx, (start_line, section_name) in enumerate(section_starts):
        # The header row with well names is 2 lines after the section label
        header_line = start_line + 2
        headers = lines[header_line].split("\t")

        # First two cols are Time and Temperature; the rest are wells
        well_names = headers[2:]

        times = []
        values = []

        # Read data rows until we hit an empty line or the next section
        row = header_line + 1
        while row < len(lines):
            parts = lines[row].split("\t")
            if len(parts) < 3 or parts[0].strip() == "":
                break
            try:
                t = time_to_hours(parts[0])
                #print(t, parts[0])
            except (ValueError, IndexError):
                break
            times.append(t)
            row_vals = [float(v) if v.strip() != "" else np.nan for v in parts[2:]]
            values.append(row_vals)
            row += 1

        df = pd.DataFrame(values, columns=well_names, index=times)
        df.index.name = "Time (h)"
        data_blocks[section_name] = df

    return data_blocks


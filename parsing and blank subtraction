def export_tidy_csv(data_blocks, groups, out_path="tidy_data.csv"):
    """
    Export all reads into a single tidy CSV with columns:
    Time_h, Well, Group, Absorbance_600, Fluorescence_510, Fluorescence_550
    """
    # Build well -> group lookup
    well_to_group = {}
    for gname, wells in groups.items():
        for w in wells:
            well_to_group[w] = gname

    records = []
    od_df  = data_blocks.get("Read 1:600")
    fl1_df = data_blocks.get("Read 2:457,510")
    fl2_df = data_blocks.get("Read 3:457,550")

    if od_df is None:
        print("No OD data found -- cannot export.")
        return

    time_vals = od_df.index.tolist()
    for well in od_df.columns:
        grp = well_to_group.get(well, "Unknown")
        od_vals  = od_df[well].values
        fl1_vals = fl1_df[well].values if (fl1_df is not None and well in fl1_df.columns) else [np.nan] * len(time_vals)
        fl2_vals = fl2_df[well].values if (fl2_df is not None and well in fl2_df.columns) else [np.nan] * len(time_vals)
        for i, t in enumerate(time_vals):
            records.append({
                "Time_h": round(t, 4),
                "Well": well,
                "Group": grp,
                "Absorbance_600":   od_vals[i],
                "Fluorescence_510": fl1_vals[i],
                "Fluorescence_550": fl2_vals[i],
            })

    tidy = pd.DataFrame(records)
    tidy.to_csv(out_path, index=False)
    print(f"\n  Tidy CSV exported -> {out_path}  ({len(tidy)} rows)")



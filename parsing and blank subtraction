def group_stats(df, groups):
    """
    Compute mean and std for each condition group over time.

    Returns dict  { group_name: {'mean': Series, 'std': Series} }
    """
    stats = {}
    for name, wells in groups.items():
        # Keep only wells present in the data
        present = [w for w in wells if w in df.columns]
        if not present:
            continue
        sub = df[present]
        stats[name] = {
            "mean": sub.mean(axis=1),
            "std":  sub.std(axis=1),
        }
    return stats




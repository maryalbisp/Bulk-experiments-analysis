# Map each sample group to the blank that should be subtracted.
# Edit this if your blank assignment is different.
BLANK_MAP = {
    "Rib Glucose + 8 uM":  "Blank Glucose + 8 uM",
    "Rib Glucose + 4 uM":  "Blank Glucose + 4 uM",          
    "Rib Glucose":          "Blank Glucose",
    "WT Glucose + 8 uM":   "Blank Glucose + 8 uM",
    "WT Glucose + 4 uM":   "Blank Glucose + 4 uM",         
    "WT Glucose":           "Blank Glucose",
}


def export_blank_subtracted(data_blocks, groups, blank_map=BLANK_MAP,
                            out_path="blank_subtracted.csv"):
    """
    Subtract the AVERAGE blank (across all blank wells for that condition)
    from every sample well at each time point.
    
    MODIFICATION: This version calculates the AVERAGE absorbance/fluorescence
    across all blank wells for a given condition, then subtracts this single
    average time-series from each sample well.
    
    Process:
    1. For each blank group (e.g., "Blank Glucose + 8 uM"):
       - If multiple blank wells exist, calculate MEAN at each time point
       - This mean time-series becomes the "blank value" for that condition
    
    2. For each sample group (e.g., "WT Glucose + 8 uM"):
       - Get corresponding blank group (e.g., "Blank Glucose + 8 uM")
       - For each sample well and each time point:
         - Subtract the average blank value at that time point
    
    Columns: Time_h, Well, Group, Blank_used,
             Absorbance_600, Fluorescence_510, Fluorescence_550

    Returns
    -------
    None (writes CSV file)
    """
    od_df  = data_blocks.get("Read 1:600")
    fl1_df = data_blocks.get("Read 2:457,510")
    fl2_df = data_blocks.get("Read 3:457,550")

    if od_df is None:
        print("No OD data found -- cannot export.")
        return

    
    # ========================================================================
    # STEP 1: PRE-COMPUTE AVERAGE BLANK TIME-SERIES FOR EACH BLANK GROUP
    # ========================================================================
    
    blank_series = {}  # { blank_group_name: {read_key: Series} }
    blank_names = [g for g in groups if g.startswith("Blank")]
    
    print(f"Found {len(blank_names)} blank groups:\n")
    
    for bname in blank_names:
        bwells = [w for w in groups[bname] if w in od_df.columns]
        if not bwells:
            print(f"  {bname}: WARNING - no wells found in data")
            continue
        
        print(f"  {bname}:")
        print(f"    Wells: {bwells}")
        
        # Calculate AVERAGE of all blank wells at each time point
        # This is the KEY MODIFICATION
        blank_series[bname] = {
            "od":  od_df[bwells].mean(axis=1),  # Mean across blank wells
            "fl1": fl1_df[bwells].mean(axis=1) if fl1_df is not None else None,
            "fl2": fl2_df[bwells].mean(axis=1) if fl2_df is not None else None,
        }

    
    # ========================================================================
    # STEP 2: SUBTRACT AVERAGE BLANK FROM EACH SAMPLE WELL
    # ========================================================================
    
    # Build well -> group lookup (sample groups only)
    sample_groups = {k: v for k, v in groups.items() if not k.startswith("Blank")}

    records = []
    time_vals = od_df.index.tolist()
    
    print(f"Processing {len(sample_groups)} sample groups:\n")

    for gname, wells in sample_groups.items():
        bname = blank_map.get(gname)
        
        if bname is None:
            print(f"  {gname}: ERROR - no blank mapping defined in BLANK_MAP")
            continue
        
        if bname not in blank_series:
            print(f"  {gname}: ERROR - blank group '{bname}' not found in data")
            continue

        bs = blank_series[bname]
        sample_wells_present = [w for w in wells if w in od_df.columns]
        


        for well in sample_wells_present:
            
            # Get raw values for this sample well
            od_raw  = od_df[well].values
            fl1_raw = fl1_df[well].values if (fl1_df is not None and well in fl1_df.columns) else [np.nan] * len(time_vals)
            fl2_raw = fl2_df[well].values if (fl2_df is not None and well in fl2_df.columns) else [np.nan] * len(time_vals)

            # Get AVERAGE blank values (pre-computed from all blank wells for this condition)
            od_blk  = bs["od"].values    # This is already the AVERAGE
            print('BLANK',od_blk[2:],np.mean(od_blk[2:]),np.std(od_blk[2:]))
     
            fl1_blk = bs["fl1"].values if bs["fl1"] is not None else np.zeros(len(time_vals))
            fl2_blk = bs["fl2"].values if bs["fl2"] is not None else np.zeros(len(time_vals))

            # Subtract AVERAGE blank from each time point
            # This ensures every sample well uses the same blank correction
            for i, t in enumerate(time_vals):
                records.append({
                    "Time_h":           round(t, 4),
                    "Well":             well,
                    "Group":            gname,
                    "Blank_used":       bname,
                    "Absorbance_600":   od_raw[i] - np.mean(od_blk[2:]),## i am subtracting the blank mean not t point
                    "Fluorescence_510": fl1_raw[i] - fl1_blk[i],
                    "Fluorescence_550": fl2_raw[i] - fl2_blk[i],
                })


    # ========================================================================
    # STEP 3: EXPORT TO CSV
    # ========================================================================
    
    tidy = pd.DataFrame(records)
    tidy.to_csv(out_path, index=False)
